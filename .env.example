# Copy this file to .env and fill in your values.
# .env is gitignored — so as to never commit real secrets.

# Stripe test-mode API keys (Stripe Dashboard → Developers → API keys)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# Stripe Dashboard sandbox URL (no trailing slash)
STRIPE_DASHBOARD_URL=https://dashboard.stripe.com

# Dashboard login credentials — only needed if using the LoginPage automated-login path.
# Normal CI runs use STRIPE_AUTH_STATE (storage state) instead.
STRIPE_DASHBOARD_EMAIL=you@example.com
STRIPE_DASHBOARD_PASSWORD=your-password
