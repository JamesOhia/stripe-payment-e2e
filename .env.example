# ====================================================================
# Stripe Sandbox credentials
# Copy this file to `.env` (which is gitignored) and fill in real values.
# In CI these are provided via GitHub Secrets (see .github/workflows).
# ====================================================================

# --- Stripe API ---
# Get from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Stripe Dashboard (for UI verification) ---
# IMPORTANT: For automation reliability, disable 2FA on this test account
# (Profile → Security → Two-step authentication → Disable for test mode).
STRIPE_DASHBOARD_URL=https://dashboard.stripe.com
STRIPE_DASHBOARD_EMAIL=your-test-email@example.com
STRIPE_DASHBOARD_PASSWORD=your-test-password

# --- Stripe API base URL (rarely changed) ---
STRIPE_API_BASE_URL=https://api.stripe.com/v1
STRIPE_API_VERSION=2024-12-18.acacia

# --- Test execution ---
HEADLESS=true
